# Find and activate the Python virtual environment silently.
# This script first checks for a standard 'venv' directory,
# then for a hidden '.venv' directory.

if [ -d "venv" ]; then
  # Activate the 'venv' virtual environment
  source venv/bin/activate
elif [ -d ".venv" ]; then
  # Activate the hidden '.venv' virtual environment
  source .venv/bin/activate
fi
